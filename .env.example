# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Local development (SQLite — no setup needed)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL — replace with your connection string)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/epi_watch?sslmode=require"
# Example providers: Neon (neon.tech), Supabase, Railway, PlanetScale

# ─────────────────────────────────────────────
# SCRAPING / CRON
# ─────────────────────────────────────────────
# Secret token to protect the /api/scrape endpoint from unauthorized calls
SCRAPE_SECRET="change-me-to-a-random-string"

# ─────────────────────────────────────────────
# AI CLASSIFICATION (Optional)
# ─────────────────────────────────────────────
# If you have an OpenAI key, AI-generated summaries will be much richer.
# Leave blank to use built-in rule-based classification.
OPENAI_API_KEY=""

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
